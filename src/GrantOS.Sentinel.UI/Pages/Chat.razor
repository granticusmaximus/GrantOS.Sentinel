@page "/chat"
@page "/chat/{ConversationId:int}"
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IOllamaChatService Ollama
@inject IConversationService Conversations
@inject IMemoryRetrievalService MemoryRetrieval
@inject IProjectWorkspaceService ProjectWorkspaces
@inject IProjectStandardService ProjectStandards
@inject ISystemPromptService SystemPrompts
@inject IModelProfileService ModelProfiles
@inject IToolAuditService Audit
@inject IEnumerable<IAgentTool> Tools
@inject Microsoft.Extensions.Options.IOptions<SentinelOptions> SentinelOptions
@inject Microsoft.Extensions.Options.IOptions<MemoryRetrievalOptions> MemoryRetrievalOptions
@inject IJSRuntime JS

<div class="chat-page">
    <h1>Chat</h1>

    <div class="chat-toolbar">
        <div class="field">
            <label>Model</label>
            <select @bind="_selectedModel" disabled="@_sending">
                @if (_models.Count == 0)
                {
                    <option value="">No models found</option>
                }
                @foreach (var m in _models)
                {
                    <option value="@m">@m</option>
                }
            </select>
        </div>
        <div class="field">
            <label>System prompt</label>
            <select @bind="_selectedPromptId" disabled="@_sending">
                <option value="">None</option>
                @foreach (var p in _prompts)
                {
                    <option value="@p.Id">@p.Name</option>
                }
            </select>
        </div>
        <label class="memory-toggle" title="Add relevant notes from the local Memory vault to the model context">
            <input type="checkbox" @bind="_useMemory" disabled="@_sending" />
            Use memory
        </label>
        <label class="memory-toggle" title="Add relevant source excerpts from indexed Projects to the model context">
            <input type="checkbox" @bind="_useProjects" disabled="@_sending" />
            Use projects
        </label>
        <label class="memory-toggle" title="Apply enabled same-scope Project Standards to model responses">
            <input type="checkbox" @bind="_useStandards" disabled="@_sending" />
            Use standards
        </label>
        <button class="btn btn-ghost btn-sm" @onclick="ResetConversation" disabled="@_sending">New thread</button>
    </div>

    @if (!_online)
    {
        <div class="alert alert-warn">
            Ollama is offline. Start it and pull a model, then reload this page.
        </div>
    }
    @if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (_retrievedMemory.Entries.Count > 0)
    {
        <div class="memory-context-note">
            <span>Memory context</span>
            @foreach (var memory in _retrievedMemory.Entries)
            {
                <span class="tag">@(memory.Pinned ? "📌 " : "")@memory.Title</span>
            }
        </div>
    }
    @if (_retrievedProjects.Documents.Count > 0)
    {
        <div class="memory-context-note">
            <span>Project context</span>
            @foreach (var document in _retrievedProjects.Documents)
            {
                <span class="tag">@document.WorkspaceName/@document.RelativePath</span>
            }
        </div>
    }
    @if (_standardContext.Standards.Count > 0)
    {
        <div class="memory-context-note">
            <span>Standards</span>
            @foreach (var standard in _standardContext.Standards)
            {
                <span class="tag">@standard.Name · P@standard.Priority</span>
            }
        </div>
    }
    @if (_pendingApproval is not null)
    {
        <div class="alert alert-warn">
            <div><strong>@_pendingApproval.ToolName</strong></div>
            <div>@_pendingApproval.Description</div>
            <div class="btn-row" style="margin-top:.5rem">
                <button class="btn btn-primary btn-sm" @onclick="() => _pendingApproval.Decision.TrySetResult(true)">Approve</button>
                <button class="btn btn-ghost btn-sm" @onclick="() => _pendingApproval.Decision.TrySetResult(false)">Deny</button>
            </div>
        </div>
    }

    <div class="chat-stream" @ref="_streamRef">
        @if (_messages.Count == 0)
        {
            <div class="empty">Send a message to start. This thread is saved locally as soon as you do.</div>
        }
        @foreach (var msg in _messages)
        {
            <div class="msg @(msg.Role == ChatRole.User ? "user" : msg.Role == ChatRole.Tool ? "tool" : "assistant")">
                <div class="who">@(msg.Role == ChatRole.User ? "you" : msg.Role == ChatRole.Tool ? $"🔧 {msg.ToolName}" : _selectedModel)</div>
                <div class="@(_sending && msg == _messages[^1] && msg.Role == ChatRole.Assistant ? "cursor" : "")">@msg.Content</div>
                @if (msg.Role == ChatRole.Assistant && HasGenerationMetrics(msg))
                {
                    <div class="generation-meta">@FormatGenerationMetrics(msg)</div>
                }
            </div>
        }
    </div>

    <div class="chat-input">
        <textarea @ref="_inputRef" @bind="_input" @bind:event="oninput" placeholder="Ask Sentinel… (Enter to send, Shift+Enter for a new line)" disabled="@_sending"></textarea>
        <button class="btn btn-primary" title="Send" @onclick="SendAsync" disabled="@(_sending || string.IsNullOrWhiteSpace(_input) || !_online)">
            @if (_sending)
            {
                <span>…</span>
            }
            else
            {
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" /></svg>
            }
        </button>
    </div>
</div>

@code {
    [Parameter] public int? ConversationId { get; set; }
    [SupplyParameterFromQuery(Name = "prompt")]
    [Parameter] public string? Prompt { get; set; }
    [SupplyParameterFromQuery(Name = "scope")]
    [Parameter] public string? RequestedScope { get; set; }

    private readonly List<ChatMessage> _messages = [];
    private List<string> _models = [];
    private List<SystemPrompt> _prompts = [];

    private string _selectedModel = "";
    private int? _selectedPromptId;
    private int? _conversationId;
    private string _input = "";
    private bool _sending;
    private bool _online;
    private string? _error;
    private bool _useMemory;
    private bool _useProjects = true;
    private bool _useStandards = true;
    private ProjectScope _scope;
    private MemoryRetrievalResult _retrievedMemory = MemoryRetrievalResult.Empty;
    private ProjectRetrievalResult _retrievedProjects = ProjectRetrievalResult.Empty;
    private StandardContextResult _standardContext = StandardContextResult.Empty;
    private PendingToolApproval? _pendingApproval;
    private readonly Dictionary<string, bool> _toolSupportByModel = [];
    private ElementReference _streamRef;
    private ElementReference _inputRef;
    private IJSObjectReference? _interopModule;
    private DotNetObjectReference<Chat>? _dotNetRef;

    private sealed class PendingToolApproval
    {
        public required string ToolName { get; init; }
        public required string Description { get; init; }
        public required TaskCompletionSource<bool> Decision { get; init; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Prompt))
            _input = Prompt.Trim();

        _useMemory = MemoryRetrievalOptions.Value.Enabled;
        _scope = ProjectScopeQueryParser.ParseOrDefault(RequestedScope, SentinelOptions.Value.DefaultScope);
        _online = await Ollama.IsAvailableAsync();
        _prompts = [.. await SystemPrompts.ListAsync()];
        _selectedPromptId = (await SystemPrompts.GetDefaultAsync())?.Id;

        var installed = _online ? (await Ollama.ListModelsAsync()).Select(m => m.Name).ToList() : [];
        var profiles = await ModelProfiles.ListAsync();
        _models = installed.Count > 0 ? installed : profiles.Select(p => p.Name).ToList();

        var defaultModel = (await ModelProfiles.GetDefaultAsync())?.Name;
        _selectedModel = _models.Contains(defaultModel ?? "") ? defaultModel! : _models.FirstOrDefault() ?? "";

        if (ConversationId is int existingId)
            await LoadConversationAsync(existingId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _interopModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/GrantOS.Sentinel.UI/chatInterop.js");

        // A MutationObserver reacts directly to DOM changes (including streamed token text
        // updates) instead of a per-render interop call, which can miss updates or lag behind
        // when Blazor coalesces several rapid StateHasChanged calls into one render.
        await _interopModule.InvokeVoidAsync("observeAndScroll", _streamRef);

        // Enter sends, Shift+Enter inserts a newline - needs a native listener since preventing
        // the newline only for a bare Enter can't be expressed as a static Blazor attribute.
        _dotNetRef = DotNetObjectReference.Create(this);
        await _interopModule.InvokeVoidAsync("bindEnterToSend", _inputRef, _dotNetRef);
    }

    [JSInvokable]
    public async Task OnEnterPressed()
    {
        if (!_sending && !string.IsNullOrWhiteSpace(_input) && _online)
            await SendAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_interopModule is not null)
        {
            try
            {
                await _interopModule.InvokeVoidAsync("unobserve", _streamRef);
                await _interopModule.InvokeVoidAsync("unbindEnterToSend", _inputRef);
                await _interopModule.DisposeAsync();
            }
            catch (JSDisconnectedException) { /* circuit already gone - nothing to clean up */ }
        }
        _dotNetRef?.Dispose();
    }

    private async Task LoadConversationAsync(int id)
    {
        var convo = await Conversations.GetAsync(id);
        if (convo is null) return;
        _conversationId = convo.Id;
        _scope = convo.Scope;
        if (!string.IsNullOrWhiteSpace(convo.ModelName) && _models.Contains(convo.ModelName))
            _selectedModel = convo.ModelName;
        _selectedPromptId = convo.SystemPromptId;
        _messages.Clear();
        _messages.AddRange(convo.Messages.Where(m => m.Role != ChatRole.System));
    }

    private void ResetConversation()
    {
        _conversationId = null;
        _scope = SentinelOptions.Value.DefaultScope;
        _messages.Clear();
        _retrievedMemory = MemoryRetrievalResult.Empty;
        _retrievedProjects = ProjectRetrievalResult.Empty;
        _standardContext = StandardContextResult.Empty;
        _error = null;
    }

    private async Task SendAsync()
    {
        if (_sending || string.IsNullOrWhiteSpace(_input)) return;
        _error = null;
        _sending = true;

        var userText = _input.Trim();
        _input = "";
        var scope = _scope;

        // Persist the conversation on first message.
        if (_conversationId is null)
        {
            var title = userText.Length > 60 ? userText[..60] + "…" : userText;
            var convo = await Conversations.CreateAsync(title, _selectedModel, _selectedPromptId, scope);
            _conversationId = convo.Id;
        }

        var userMessage = new ChatMessage { Role = ChatRole.User, Content = userText };
        _messages.Add(userMessage);
        await Conversations.AddMessageAsync(_conversationId!.Value, ChatRole.User, userText, null);

        try
        {
            _retrievedMemory = _useMemory
                ? await MemoryRetrieval.RetrieveAsync(userText, scope)
                : MemoryRetrievalResult.Empty;
        }
        catch (Exception ex)
        {
            _retrievedMemory = MemoryRetrievalResult.Empty;
            _error = $"Memory retrieval was skipped: {ex.Message}";
        }

        try
        {
            _retrievedProjects = _useProjects
                ? await ProjectWorkspaces.RetrieveAsync(userText, scope)
                : ProjectRetrievalResult.Empty;
        }
        catch (Exception ex)
        {
            _retrievedProjects = ProjectRetrievalResult.Empty;
            _error = $"Project retrieval was skipped: {ex.Message}";
        }

        try
        {
            _standardContext = _useStandards
                ? await ProjectStandards.GetContextAsync(scope)
                : StandardContextResult.Empty;
        }
        catch (Exception ex)
        {
            _standardContext = StandardContextResult.Empty;
            _error = $"Project standards were skipped: {ex.Message}";
        }

        // A user turn can take several rounds: model replies with tool_calls, we run (or
        // decline) them, feed the result back, and let the model continue - capped so a
        // misbehaving model can't loop forever.
        const int maxToolRounds = 5;
        for (var round = 0; round <= maxToolRounds; round++)
        {
            var assistantMessage = new ChatMessage { Role = ChatRole.Assistant, Content = "" };
            _messages.Add(assistantMessage);

            var request = await BuildRequestAsync();
            var success = false;
            IReadOnlyList<OllamaToolCall>? requestedToolCalls = null;
            MessageGenerationMetrics? generationMetrics = null;

            try
            {
                await foreach (var evt in Ollama.StreamChatAsync(request))
                {
                    switch (evt)
                    {
                        case OllamaContentDelta delta:
                            assistantMessage.Content += delta.Text;
                            await InvokeAsync(StateHasChanged);
                            break;
                        case OllamaToolCallsReady toolCalls:
                            requestedToolCalls = toolCalls.ToolCalls;
                            break;
                        case OllamaGenerationCompleted completed:
                            generationMetrics = new MessageGenerationMetrics(
                                completed.PromptTokenCount,
                                completed.ResponseTokenCount,
                                completed.TotalDurationNanoseconds,
                                completed.LoadDurationNanoseconds,
                                completed.PromptEvalDurationNanoseconds,
                                completed.EvalDurationNanoseconds);
                            ApplyGenerationMetrics(assistantMessage, generationMetrics);
                            break;
                    }
                }
                success = true;
            }
            catch (Exception ex)
            {
                _error = $"The model call failed: {ex.Message}";
            }

            // Persist whatever text we received (even a partial reply is worth keeping).
            if (assistantMessage.Content.Length > 0)
                await Conversations.AddMessageAsync(_conversationId.Value, ChatRole.Assistant, assistantMessage.Content, generationMetrics);
            else if (requestedToolCalls is null)
                _messages.Remove(assistantMessage);

            await Audit.LogAsync(
                toolName: "ollama",
                action: "chat",
                parameters: $"model={_selectedModel}; scope={scope}; memories={_retrievedMemory.Entries.Count}; projectDocuments={_retrievedProjects.Documents.Count}; standards={_standardContext.Standards.Count}",
                result: success ? $"ok ({assistantMessage.Content.Length} chars)" : "failed",
                success: success,
                scope: scope);

            if (!success || requestedToolCalls is not { Count: > 0 })
                break; // plain text reply or a failure - either way, this turn is over

            await HandleToolCallsAsync(requestedToolCalls, scope);
            // loop back: BuildRequestAsync will now include the tool result(s) so the model can continue
        }

        _sending = false;
    }

    private static void ApplyGenerationMetrics(ChatMessage message, MessageGenerationMetrics metrics)
    {
        message.PromptTokenCount = metrics.PromptTokenCount;
        message.TokenCount = metrics.ResponseTokenCount;
        message.TotalDurationNanoseconds = metrics.TotalDurationNanoseconds;
        message.LoadDurationNanoseconds = metrics.LoadDurationNanoseconds;
        message.PromptEvalDurationNanoseconds = metrics.PromptEvalDurationNanoseconds;
        message.EvalDurationNanoseconds = metrics.EvalDurationNanoseconds;
    }

    private static bool HasGenerationMetrics(ChatMessage message) =>
        message.PromptTokenCount.HasValue || message.TokenCount.HasValue || message.TotalDurationNanoseconds.HasValue;

    private static string FormatGenerationMetrics(ChatMessage message)
    {
        var parts = new List<string>();
        if (message.PromptTokenCount is int promptTokens)
            parts.Add($"{promptTokens:N0} prompt");
        if (message.TokenCount is int responseTokens)
            parts.Add($"{responseTokens:N0} generated");
        if (message.TotalDurationNanoseconds is long totalNanoseconds)
            parts.Add(FormatDuration(totalNanoseconds));
        if (message.TokenCount is > 0 && message.EvalDurationNanoseconds is > 0)
        {
            var tokensPerSecond = message.TokenCount.Value / (message.EvalDurationNanoseconds.Value / 1_000_000_000d);
            parts.Add($"{tokensPerSecond:F1} tok/s");
        }
        return string.Join(" · ", parts);
    }

    private static string FormatDuration(long nanoseconds)
    {
        var duration = TimeSpan.FromTicks(nanoseconds / 100);
        return duration.TotalMinutes >= 1
            ? $"{duration.TotalMinutes:F1}m"
            : duration.TotalSeconds >= 1
                ? $"{duration.TotalSeconds:F1}s"
                : $"{duration.TotalMilliseconds:F0}ms";
    }

    private async Task HandleToolCallsAsync(IReadOnlyList<OllamaToolCall> requestedToolCalls, ProjectScope scope)
    {
        foreach (var call in requestedToolCalls)
        {
            var tool = Tools.FirstOrDefault(t => t.Name == call.Function.Name);
            string resultText;

            if (tool is null)
            {
                resultText = $"Unknown tool '{call.Function.Name}'.";
                await Audit.LogAsync(call.Function.Name, "unknown-tool", null, resultText, false, scope);
            }
            else
            {
                var validation = tool.ValidateInvocation(call.Function.Arguments);
                if (!validation.IsValid)
                {
                    resultText = $"Action rejected by Sentinel's safety policy: {validation.Error}";
                    await Audit.LogAsync(tool.Name, "rejected", tool.DescribeInvocation(call.Function.Arguments), resultText, false, scope);
                }
                else
                {
                    var description = tool.DescribeInvocation(call.Function.Arguments);
                    var approval = new PendingToolApproval
                    {
                        ToolName = tool.Name,
                        Description = description,
                        Decision = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously)
                    };
                    _pendingApproval = approval;
                    await InvokeAsync(StateHasChanged);

                    var approved = await approval.Decision.Task;
                    _pendingApproval = null;

                    if (!approved)
                    {
                        resultText = "The user denied this action.";
                        await Audit.LogAsync(tool.Name, "denied", description, null, false, scope);
                    }
                    else
                    {
                        var result = await tool.ExecuteAsync(call.Function.Arguments);
                        resultText = result.Output;
                        await Audit.LogAsync(tool.Name, "execute", description, result.Output, result.Success, scope);
                    }
                }
            }

            var toolArgsJson = call.Function.Arguments.GetRawText();
            var toolMessage = new ChatMessage
            {
                Role = ChatRole.Tool,
                Content = resultText,
                ToolName = call.Function.Name,
                ToolArguments = toolArgsJson
            };
            _messages.Add(toolMessage);
            await Conversations.AddMessageAsync(_conversationId!.Value, ChatRole.Tool, resultText, null, call.Function.Name, toolArgsJson);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<OllamaChatRequest> BuildRequestAsync()
    {
        var wire = new List<OllamaMessage>();

        if (_selectedPromptId is int promptId)
        {
            var prompt = await SystemPrompts.GetAsync(promptId);
            if (prompt is not null)
                wire.Add(new OllamaMessage("system", prompt.Content));
        }

        if (!string.IsNullOrWhiteSpace(_standardContext.PromptText))
            wire.Add(new OllamaMessage("system", _standardContext.PromptText));

        if (!string.IsNullOrWhiteSpace(_retrievedMemory.PromptText))
            wire.Add(new OllamaMessage("system", _retrievedMemory.PromptText));

        if (!string.IsNullOrWhiteSpace(_retrievedProjects.PromptText))
            wire.Add(new OllamaMessage("system", _retrievedProjects.PromptText));

        foreach (var m in _messages.Where(m => m.Role != ChatRole.System))
        {
            if (m.Role == ChatRole.Assistant && string.IsNullOrEmpty(m.Content)) continue; // skip the pending placeholder
            var role = m.Role switch
            {
                ChatRole.User => "user",
                ChatRole.Tool => "tool",
                _ => "assistant"
            };
            wire.Add(m.Role == ChatRole.Tool
                ? new OllamaMessage(role, m.Content) { ToolName = m.ToolName }
                : new OllamaMessage(role, m.Content));
        }

        var profile = (await ModelProfiles.ListAsync()).FirstOrDefault(p => p.Name == _selectedModel);
        var options = profile is null
            ? null
            : new OllamaOptions { NumCtx = profile.ContextLength, Temperature = profile.Temperature };

        // Ollama returns a 400 for the *whole* request if "tools" is sent to a model that
        // doesn't declare tool-calling support (confirmed live: gemma3 rejects it outright),
        // so this has to be checked per model before attaching anything.
        var modelSupportsTools = await SupportsToolsAsync(_selectedModel);
        var toolDefs = modelSupportsTools
            ? Tools
                .Select(t => new OllamaToolDefinition
                {
                    Function = new OllamaFunctionDefinition
                    {
                        Name = t.Name,
                        Description = t.Description,
                        Parameters = t.ParametersSchema
                    }
                })
                .ToList()
            : [];

        return new OllamaChatRequest
        {
            Model = _selectedModel,
            Messages = wire,
            Stream = true,
            Options = options,
            Tools = toolDefs.Count > 0 ? toolDefs : null
        };
    }

    private async Task<bool> SupportsToolsAsync(string model)
    {
        if (_toolSupportByModel.TryGetValue(model, out var cached))
            return cached;

        var supported = await Ollama.SupportsToolCallingAsync(model);
        _toolSupportByModel[model] = supported;
        return supported;
    }
}
